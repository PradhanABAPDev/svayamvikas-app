<!--
  SvayamVikās — AndroidManifest.xml additions
  ══════════════════════════════════════════════════════════════════════════
  After running `npx cap add android`, MERGE these into:
    android/app/src/main/AndroidManifest.xml

  The full manifest is generated by Capacitor. You only need to add/modify
  the sections marked "ADD THIS" below.
  ══════════════════════════════════════════════════════════════════════════
-->

<!-- ══ FULL REFERENCE MANIFEST (what your file should look like) ══════════ -->
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.svayam.vikas">

    <!-- ── Permissions ──────────────────────────────────────────────────── -->
    <!-- Internet: required for AI companion + multiplayer sync -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Network state: used to show online/offline mode in game -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Keep screen on: prevents sleep during gameplay -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibration: haptic feedback for boss hits, skill casts -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ── Hardware Features ─────────────────────────────────────────────── -->
    <!-- OpenGL ES 3.0: required by Three.js / WebGL for high-end graphics -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <!-- Touchscreen: game requires touch input -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true" />

    <!-- Landscape + Portrait orientation support -->
    <uses-feature android:name="android.hardware.screen.landscape" android:required="false" />

    <!-- ── Application Block ─────────────────────────────────────────────── -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"

        <!-- CRITICAL: Enables GPU-accelerated rendering for WebGL -->
        android:hardwareAccelerated="true"

        <!-- Network security config: allow HTTPS only, block HTTP -->
        android:networkSecurityConfig="@xml/network_security_config"

        <!-- Large heap: Three.js + game assets need more memory -->
        android:largeHeap="true"

        <!-- App can be installed on external storage (SD card) -->
        android:installLocation="auto">

        <!-- ── Main Activity ─────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/title_activity_main"

            <!-- No window title (game is full-screen) -->
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"

            <!-- Keep activity alive on rotation instead of destroying it -->
            <!-- This prevents Three.js context loss on device rotation  -->

            <!-- Launch mode: no task stacking (single game instance) -->
            android:launchMode="singleTask"

            <!-- Full screen + no ActionBar -->
            android:theme="@style/AppTheme.NoActionBar"

            <!-- Screen orientation: sensor-based (game supports all) -->
            android:screenOrientation="sensorLandscape">

            <!-- App launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: svayamvikas://open?quest=xyz -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="svayamvikas" />
            </intent-filter>

            <!-- HTTPS deep link: https://svayamvikas.app/join?room=xyz -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="svayamvikas.app" />
            </intent-filter>

        </activity>

        <!-- File Provider: needed for sharing screenshots from game -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
