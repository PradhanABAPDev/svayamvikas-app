{
  "name": "svayamvikas",
  "version": "1.0.0",
  "description": "SvayamVikās — Self-Evolution · Sanskrit-Philosophy AI Multiplayer Game",
  "private": true,
  "homepage": "https://svayamvikas.app",
  "author": {
    "name": "SvayamVikās Team",
    "email": "dev@svayamvikas.app"
  },
  "keywords": ["game", "sanskrit", "ai", "multiplayer", "webgl"],

  "scripts": {
    "start":          "npx serve www -l 3000",
    "build":          "node scripts/build.js",

    "cap:sync":       "npx cap sync",
    "cap:copy":       "npx cap copy",
    "cap:update":     "npx cap update",

    "android:open":   "npx cap open android",
    "android:run":    "npx cap run android",
    "android:build":  "node scripts/build-android.js",
    "android:release":"node scripts/build-android.js --release",

    "ios:open":       "npx cap open ios",
    "ios:run":        "npx cap run ios",
    "ios:build":      "node scripts/build-ios.js",
    "ios:release":    "node scripts/build-ios.js --release",

    "setup":          "node scripts/setup.js",
    "icons":          "node scripts/generate-icons.js",
    "splash":         "node scripts/generate-splash.js",
    "validate":       "node scripts/validate-release.js"
  },

  "dependencies": {
    "@capacitor/android":             "^6.0.0",
    "@capacitor/app":                 "^6.0.0",
    "@capacitor/core":                "^6.0.0",
    "@capacitor/haptics":             "^6.0.0",
    "@capacitor/ios":                 "^6.0.0",
    "@capacitor/keyboard":            "^6.0.0",
    "@capacitor/network":             "^6.0.0",
    "@capacitor/screen-orientation":  "^6.0.0",
    "@capacitor/splash-screen":       "^6.0.0",
    "@capacitor/status-bar":          "^6.0.0",
    "@capacitor-community/keep-awake":"^5.0.0"
  },

  "devDependencies": {
    "@capacitor/cli":   "^6.0.0",
    "typescript":       "^5.4.0",
    "sharp":            "^0.33.0",
    "serve":            "^14.2.0"
  }
}
